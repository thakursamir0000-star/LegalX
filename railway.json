{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "dockerfile"
  },
  "deploy": {
    "startCommand": "cd backend && uvicorn main:app --host 0.0.0.0 --port 8000",
    "restartPolicyMaxRetries": 5
  },
  "variables": {
    "GEMINI_API_KEY": {
      "description": "Google Gemini API Key from aistudio.google.com",
      "value": ""
    },
    "GOOGLE_API_KEY": {
      "description": "Alternative: Google API Key",
      "value": ""
    }
  }
}
